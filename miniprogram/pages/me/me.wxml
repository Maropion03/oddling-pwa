<view class="page" wx:if="{{state && state.avatar}}"><text class="eyebrow">YOUR SETTINGS</text><view class="identity"><oddling-avatar parts="{{state.avatar.parts}}" name="{{state.avatar.name}}" size="small"/><view><text class="title">{{state.avatar.name}}</text><text>{{state.entries.length}} 次回答 · {{state.stickers.length}} 张贴纸</text></view></view><view class="section"><text class="section__title">角色名字</text><input class="input" maxlength="12" value="{{name}}" bindinput="inputName"/><button class="button" loading="{{saving}}" bindtap="saveName">保存名字</button></view><view class="section"><text class="section__title">分享管理</text><view wx:if="{{state.shares.length}}"><button wx:for="{{state.shares}}" wx:key="id" class="row" data-token="{{item.id}}" bindtap="manageShare"><view><text>{{item.snapshot.name}} 的分享</text><text class="row__note">{{item.expiresAt ? '有效期至 ' + item.expiresAt : '永久有效'}}</text></view><text>›</text></button></view><text wx:else class="none">还没有发出分享</text></view><view class="section"><text class="section__title">数据与隐私</text><button class="row" bindtap="exportData"><view><text>导出全部数据</text><text class="row__note">生成角色、回答、变异、贴纸和分享记录的 JSON 文件</text></view><text>›</text></button><button class="row row--danger" bindtap="deleteAccount"><view><text>删除账户与所有数据</text><text class="row__note">这个操作不能撤销</text></view><text>›</text></button></view><text wx:if="{{message}}" class="message">{{message}}</text></view>
