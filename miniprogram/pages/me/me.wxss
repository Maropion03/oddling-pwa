.identity { display: flex; align-items: center; gap: 18rpx; margin: 14rpx 0 52rpx; }.identity > view:last-child { display: grid; gap: 9rpx; color: #55564F; font-size: 23rpx; }.identity .title { color: #202124; font-size: 42rpx; }.section { display: grid; gap: 18rpx; margin-bottom: 44rpx; }.section__title { font-size: 33rpx; font-weight: 900; }.row { display: flex; justify-content: space-between; align-items: center; width: 100%; padding: 24rpx 0; border-top: 3rpx solid #202124; border-radius: 0; background: transparent; color: #202124; text-align: left; }.row:last-child { border-bottom: 3rpx solid #202124; }.row::after { border: 0; }.row view { display: grid; gap: 8rpx; }.row text { font-size: 28rpx; font-weight: 850; }.row__note { color: #55564F; font-size: 22rpx !important; font-weight: 400 !important; }.row--danger text { color: #B62E24; }.row--danger .row__note { color: #B62E24; }.none { padding: 20rpx 0; color: #55564F; font-size: 24rpx; }.message { color: #2B59C3; font-size: 25rpx; }
