.progress { display: flex; align-items: center; gap: 16rpx; margin-bottom: 72rpx; font-family: monospace; font-weight: 800; }.progress__line { flex: 1; height: 8rpx; overflow: hidden; background: #E9E0C5; }.progress__line view { height: 100%; background: #2B59C3; }.choices { margin-top: 42rpx; }.choice { display: flex; align-items: center; justify-content: space-between; min-height: 118rpx; margin-bottom: 16rpx; padding: 20rpx 22rpx; border: 4rpx solid #202124; border-radius: 18rpx; background: #FFFDF4; color: #202124; text-align: left; }.choice::after { border: 0; }.choice view { display: grid; gap: 7rpx; }.choice text { font-size: 30rpx; font-weight: 850; }.choice__note { color: #55564F; font-size: 23rpx !important; font-weight: 400 !important; }.choice--selected { background: #D2FF45; box-shadow: 5rpx 5rpx 0 #202124; }.actions { display: flex; justify-content: space-between; gap: 16rpx; margin-top: 50rpx; }.actions .button { flex: 1; }.error { display: block; margin-top: 18rpx; color: #B62E24; }.generating { min-height: 100vh; display: grid; align-content: center; justify-items: center; gap: 28rpx; padding: 40rpx; text-align: center; }.generating .title, .reveal .title { display: grid; gap: 8rpx; }.orbit { width: 280rpx; height: 280rpx; border: 7rpx dashed #2B59C3; border-radius: 50%; animation: spin 2.4s linear infinite; }.reveal { display: grid; gap: 24rpx; text-align: center; }.reveal .button { margin-top: 24rpx; }.reveal .input { text-align: center; } @keyframes spin { to { transform: rotate(360deg); } }
