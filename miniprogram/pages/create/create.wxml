<view class="page" wx:if="{{phase === 'questions'}}"><view class="progress"><text>0{{step + 1}}</text><view class="progress__line"><view style="width: {{(step + 1) * 25}}%"></view></view><text>04</text></view><block wx:if="{{step < 3}}"><text class="eyebrow">QUESTION 0{{step + 1}}</text><text class="title">{{questions[step].prompt}}</text><view class="choices"><button wx:for="{{questions[step].options}}" wx:key="id" class="choice {{choices[questions[step].id] === item.id ? 'choice--selected' : ''}}" data-question-id="{{questions[step].id}}" data-option-id="{{item.id}}" bindtap="choose"><view><text>{{item.label}}</text><text class="choice__note">{{item.note}}</text></view><text>{{choices[questions[step].id] === item.id ? '✓' : index + 1}}</text></button></view></block><block wx:else><text class="eyebrow">LAST QUESTION</text><text class="title">如果今天能偷偷留下一个东西你会留什么</text><textarea class="textarea" maxlength="60" placeholder="一句话就好" value="{{freeText}}" bindinput="inputFreeText"></textarea><view class="meta"><text>回答不会公开</text><text>{{freeText.length}}/60</text></view></block><text wx:if="{{error}}" class="error">{{error}}</text><view class="actions"><button class="button button--ghost" disabled="{{step === 0}}" bindtap="previous">上一题</button><button class="button button--primary" bindtap="next">{{step === 3 ? '开始生成' : '下一题'}}</button></view></view><view class="generating" wx:elif="{{phase === 'generating'}}"><view class="orbit"></view><text class="eyebrow">正在把答案揉成一团</text><view class="title"><text>先长眼睛</text><text>再决定脾气</text></view></view><view class="page reveal" wx:else><text class="eyebrow">SPECIMEN FOUND</text><oddling-avatar parts="{{avatar.parts}}" name="{{name}}"/><view class="title"><text>它有一点像你</text><text>但不打算承认</text></view><input class="input" maxlength="12" value="{{name}}" bindinput="inputName"/><view class="meta"><text>外观不能捏 名字可以改</text><text>{{name.length}}/12</text></view><text wx:if="{{error}}" class="error">{{error}}</text><button class="button button--primary" bindtap="enterHome">带它回巢穴</button></view>
