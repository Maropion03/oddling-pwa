.top { display: flex; justify-content: space-between; align-items: flex-start; }.count { padding: 12rpx 16rpx; border: 3rpx solid #202124; border-radius: 999rpx; background: #FFFDF4; font-family: monospace; font-size: 21rpx; }.stage { display: grid; justify-items: center; margin: 40rpx 0 26rpx; }.caption { max-width: 620rpx; color: #55564F; font-size: 28rpx; line-height: 1.6; text-align: center; }.daily,.done { border-top: 4rpx solid #202124; padding-top: 28rpx; }.daily__head { display: flex; align-items: center; justify-content: space-between; }.reroll { padding: 12rpx 0; background: transparent; color: #2B59C3; font-size: 24rpx; }.reroll::after { border: 0; }.daily__question,.done__title { display: block; margin: 12rpx 0 26rpx; font-size: 40rpx; font-weight: 900; line-height: 1.18; }.daily .button,.done .button { margin-top: 26rpx; }.done { display: grid; gap: 18rpx; }.error { display: block; margin-top: 20rpx; color: #B62E24; text-align: center; }
