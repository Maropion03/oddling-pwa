<view class="page" wx:if="{{state && state.avatar}}"><view class="top"><view><text class="eyebrow">YOUR ODDLING</text><text class="title">{{state.avatar.name}}</text></view><text class="count">变异 {{state.avatar.mutationCount}}</text></view><view class="stage"><oddling-avatar parts="{{state.avatar.parts}}" name="{{state.avatar.name}}" size="large"/><text class="caption">{{entry ? entry.response : '它今天还没有形成新的意见'}}</text></view><view wx:if="{{entry}}" class="done"><text class="eyebrow">TODAY IS ARCHIVED</text><text class="done__title">今天的变化已经被它收好</text><text>{{entry.mutation.label}} · {{entry.sticker.title}}</text><button class="button button--blue" bindtap="openResult">查看今日存档</button></view><view wx:else class="daily"><view class="daily__head"><text class="eyebrow">TODAY WEIRD QUESTION</text><button class="reroll" disabled="{{busy}}" bindtap="reroll">换一题</button></view><text class="daily__question">{{question.prompt}}</text><textarea class="textarea" maxlength="60" placeholder="一句话就好" value="{{answer}}" bindinput="inputAnswer"></textarea><view class="meta"><text>提交后今天不能重答</text><text>{{answer.length}}/60</text></view><button class="button button--primary" disabled="{{busy || !answer}}" bindtap="submit">{{busy ? '正在消化' : '喂给它'}}</button></view><text wx:if="{{error}}" class="error">{{error}}</text></view><view class="page empty" wx:else><text>正在寻找分身</text></view>
