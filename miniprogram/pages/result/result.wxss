.response { display: grid; gap: 18rpx; padding: 28rpx 0; border-top: 4rpx solid #202124; border-bottom: 4rpx solid #202124; font-size: 28rpx; line-height: 1.5; }.response__answer { color: #55564F; }.mutation { display: grid; gap: 8rpx; padding: 28rpx 0; }.mutation__label { color: #2B59C3; font-size: 36rpx; font-weight: 900; }.sticker { display: grid; gap: 10rpx; margin: 8rpx 0 32rpx; padding: 28rpx; border: 4rpx solid #202124; border-radius: 24rpx; background: #F3CB42; box-shadow: 6rpx 6rpx 0 #202124; }.sticker__type { font-family: monospace; font-size: 21rpx; font-weight: 800; }.sticker__title { font-size: 38rpx; font-weight: 900; }.poster { display: grid; gap: 16rpx; margin: 0 0 32rpx; }.poster__formats { display: flex; gap: 12rpx; }.poster__formats button { flex: 1; padding: 16rpx; border: 3rpx solid #202124; border-radius: 14rpx; background: #FFFDF4; font-size: 24rpx; }.poster__formats button::after { border: 0; }.poster__formats .active { background: #D2FF45; }.poster__canvas { position: fixed; left: -3000rpx; width: 300rpx; height: 400rpx; }.privacy { display: block; margin: 18rpx 0 12rpx; color: #55564F; font-size: 22rpx; text-align: center; }.error { display: block; margin-bottom: 16rpx; color: #B62E24; }
