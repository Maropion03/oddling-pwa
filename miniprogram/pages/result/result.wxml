<view class="page" wx:if="{{state && entry}}"><text class="eyebrow">TODAY IS ARCHIVED</text><oddling-avatar parts="{{state.avatar.parts}}" name="{{state.avatar.name}}"/><text class="title">{{entry.sticker.title}}</text><view class="response"><text>{{entry.question}}</text><text class="response__answer">{{entry.answer}}</text></view><view class="mutation"><text>新变异</text><text class="mutation__label">{{entry.mutation.label}}</text><text>{{entry.response}}</text></view><view class="sticker"><text class="sticker__type">TODAY'S MUTATION</text><text class="sticker__title">{{entry.sticker.title}}</text><text>{{entry.sticker.subtitle}}</text></view><view class="poster"><text class="eyebrow">READY TO POST</text><view class="poster__formats"><button class="{{format === 'portrait' ? 'active' : ''}}" data-format="portrait" bindtap="chooseFormat">3:4</button><button class="{{format === 'square' ? 'active' : ''}}" data-format="square" bindtap="chooseFormat">1:1</button></view><button class="button" loading="{{saving}}" bindtap="savePoster">保存发布卡片</button><canvas type="2d" id="poster" class="poster__canvas"></canvas></view><text wx:if="{{error}}" class="error">{{error}}</text><button wx:if="{{!token}}" class="button button--blue" loading="{{sharing}}" bindtap="prepareShare">发给一个熟人</button><button wx:else class="button button--blue" open-type="share">发送小程序卡片</button><text class="privacy">分享只包含角色快照和贴纸 不包含你的回答</text><button class="button button--ghost" bindtap="goBack">返回巢穴</button></view>
