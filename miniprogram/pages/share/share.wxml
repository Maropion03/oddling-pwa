<view class="page" wx:if="{{share}}"><text class="eyebrow">A FRIEND'S ODDLING</text><oddling-avatar parts="{{share.snapshot.parts}}" name="{{share.snapshot.name}}"/><text class="title">{{share.snapshot.name}}</text><text class="lede">{{share.snapshot.publicLine}}</text><view wx:if="{{interaction}}" class="after"><text class="eyebrow">YOU LEFT A TRACE</text><text class="after__title">{{interaction.sticker.title}}</text><text>{{interaction.response}}</text></view><view wx:else class="actions"><text class="action-title">你想对它做什么</text><button class="action" data-action="poke" loading="{{busy}}" bindtap="act"><text>戳一下</text><text class="action__note">看看它会不会装作没事</text></button><button class="action" data-action="feed" loading="{{busy}}" bindtap="act"><text>投喂怪东西</text><text class="action__note">递给它一个不太合理的东西</text></button><button class="action" data-action="label" loading="{{busy}}" bindtap="act"><text>贴个标签</text><text class="action__note">给它留一句最多 12 个字的话</text></button></view><text wx:if="{{error}}" class="error">{{error}}</text><view class="dialog" wx:if="{{showLabel}}"><view class="dialog__body"><text class="title">贴个标签</text><input class="input" maxlength="12" focus value="{{labelText}}" bindinput="inputLabel" placeholder="例如 今天很勇敢"/><view><button class="button button--ghost" bindtap="cancelLabel">取消</button><button class="button button--primary" data-action="label" bindtap="act">贴上去</button></view></view></view></view><view class="page empty" wx:elif="{{!loading}}"><text>{{error || '分享不存在或已过期'}}</text></view>
