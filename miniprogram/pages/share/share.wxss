.actions { margin-top: 44rpx; }.action-title { display: block; margin-bottom: 12rpx; font-size: 36rpx; font-weight: 900; }.action { display: grid; justify-items: start; gap: 7rpx; width: 100%; padding: 24rpx 4rpx; border-top: 3rpx solid #202124; border-radius: 0; background: transparent; color: #202124; text-align: left; }.action:last-child { border-bottom: 3rpx solid #202124; }.action::after { border: 0; }.action text { font-size: 30rpx; font-weight: 900; }.action__note { color: #55564F; font-size: 23rpx !important; font-weight: 400 !important; }.after { display: grid; gap: 12rpx; margin-top: 40rpx; padding: 28rpx; border: 4rpx solid #202124; border-radius: 22rpx; background: #D2FF45; }.after__title { font-size: 36rpx; font-weight: 900; }.dialog { position: fixed; z-index: 10; inset: 0; display: grid; align-items: end; background: rgba(32,33,36,.42); }.dialog__body { display: grid; gap: 24rpx; padding: 36rpx 32rpx 52rpx; border-radius: 32rpx 32rpx 0 0; background: #F3EEDC; }.dialog__body > view { display: flex; gap: 16rpx; }.dialog__body .button { flex: 1; }.error { display: block; margin-top: 22rpx; color: #B62E24; }
