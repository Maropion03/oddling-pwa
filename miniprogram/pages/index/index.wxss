.launch { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 22rpx; background: #F3EEDC; }.launch__mark { width: 112rpx; height: 112rpx; display: grid; place-items: center; border: 7rpx solid #202124; border-radius: 50%; background: #F3CB42; font-size: 80rpx; font-weight: 900; line-height: 1; }.launch__word { font-family: Impact, sans-serif; font-size: 72rpx; font-weight: 900; letter-spacing: -5rpx; }.launch__hint,.launch__error { color: #55564F; font-size: 28rpx; }.launch__error { color: #B62E24; }
