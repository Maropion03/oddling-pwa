<view class="page" wx:if="{{state}}"><text class="eyebrow">ARCHIVE OF SMALL CHANGES</text><view class="heading"><text class="title">贴纸册</text><text>{{state.mutations.length}} 次变异 · {{state.stickers.length}} 张贴纸</text></view><view class="tabs"><button class="{{tab === 'mutations' ? 'active' : ''}}" data-tab="mutations" bindtap="selectTab">变异谱</button><button class="{{tab === 'stickers' ? 'active' : ''}}" data-tab="stickers" bindtap="selectTab">每日贴纸</button><button class="{{tab === 'relations' ? 'active' : ''}}" data-tab="relations" bindtap="selectTab">关系事件</button></view><view wx:if="{{items.length}}" class="list"><view wx:for="{{items}}" wx:key="id" class="item"><block wx:if="{{tab === 'mutations'}}"><text class="item__date">{{item.date}}</text><text class="item__title">{{item.label}}</text><text>{{item.slot}} · {{item.token}}</text></block><block wx:else><text class="item__date">{{item.date}}</text><text class="item__title">{{item.title}}</text><text>{{item.subtitle}}</text></block></view></view><view wx:else class="empty"><text>这里还没有东西</text><text>继续喂它一句话吧</text></view></view>
