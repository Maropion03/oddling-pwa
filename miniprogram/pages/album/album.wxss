.heading { display: flex; align-items: end; justify-content: space-between; gap: 18rpx; }.heading > text:last-child { color: #55564F; font-size: 22rpx; text-align: right; }.tabs { display: flex; margin: 44rpx 0 24rpx; border-bottom: 3rpx solid #202124; }.tabs button { flex: 1; padding: 18rpx 4rpx; background: transparent; color: #55564F; font-size: 23rpx; }.tabs button::after { border: 0; }.tabs .active { color: #202124; font-weight: 900; box-shadow: inset 0 -8rpx 0 #D2FF45; }.list { display: grid; gap: 14rpx; }.item { display: grid; gap: 7rpx; padding: 24rpx 0; border-bottom: 3rpx solid #202124; color: #55564F; font-size: 25rpx; }.item__date { color: #2B59C3; font-family: monospace; font-size: 21rpx; }.item__title { color: #202124; font-size: 33rpx; font-weight: 900; }
