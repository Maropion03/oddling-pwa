:host { display: block; }
.avatar { position: relative; width: 360rpx; height: 360rpx; margin: 0 auto; }
.avatar--small { width: 150rpx; height: 150rpx; transform: scale(.92); transform-origin: center; }
.avatar--medium { width: 280rpx; height: 280rpx; }
.avatar--large { width: 430rpx; height: 430rpx; }
.avatar__body { position: absolute; z-index: 2; left: 13%; top: 17%; width: 72%; height: 68%; border: 8rpx solid #202124; background: #FF6F59; animation: float 3.6s ease-in-out infinite; }
.avatar--coral .avatar__body { background: #FF6F59; }.avatar--blue .avatar__body { background: #2B59C3; }.avatar--yellow .avatar__body { background: #F3CB42; }.avatar--green .avatar__body { background: #D2FF45; }.avatar--violet .avatar__body { background: #A984E8; }
.avatar--bean .avatar__body { border-radius: 48% 52% 46% 54% / 42% 48% 56% 58%; }.avatar--pear .avatar__body { border-radius: 48% 48% 44% 44% / 34% 34% 62% 62%; }.avatar--cloud .avatar__body { border-radius: 42% 56% 45% 58% / 45% 38% 60% 55%; }.avatar--drop .avatar__body { border-radius: 58% 42% 52% 48% / 32% 35% 65% 68%; transform: rotate(8deg); }.avatar--pebble .avatar__body { border-radius: 48% 52% 53% 47% / 52% 42% 58% 48%; }
.avatar__eye { position: absolute; z-index: 3; top: 38%; width: 11%; height: 13%; border-radius: 50%; background: #202124; animation: blink 4s infinite; }.avatar__eye--left { left: 28%; }.avatar__eye--right { right: 28%; }
.avatar__eye--wide { width: 16%; height: 17%; }.avatar__eye--line { height: 4rpx; top: 44%; border-radius: 0; }.avatar__eye--sleepy { height: 7rpx; top: 44%; border-radius: 50%; transform: rotate(-8deg); }.avatar__eye--spark { background: #F3CB42; border: 6rpx solid #202124; }.avatar__eye--side { width: 9%; height: 11%; }.avatar__eye--mismatch.avatar__eye--right { border-radius: 50% 0 50% 0; }.avatar__eye--moon.avatar__eye--left { background: #F3EEDC; border: 7rpx solid #202124; }
.avatar__mouth { position: absolute; z-index: 3; left: 40%; top: 62%; width: 22%; height: 10%; border-bottom: 8rpx solid #202124; border-radius: 0 0 50% 50%; }.avatar__mouth--o { left: 45%; width: 12%; height: 13%; border: 7rpx solid #202124; border-radius: 50%; }.avatar__mouth--tiny { width: 12%; left: 44%; height: 2rpx; top: 67%; border-bottom-width: 7rpx; }.avatar__mouth--fang { border-bottom-color: #202124; }.avatar__mouth--wave { transform: rotate(-6deg); }
.avatar__head { position: absolute; z-index: 4; left: 43%; top: 1%; width: 20%; height: 21%; }.avatar__head--sprout::before { content: ""; position: absolute; left: 40%; top: 6%; width: 15rpx; height: 65rpx; border-left: 7rpx solid #202124; transform: rotate(-12deg); }.avatar__head--sprout::after { content: ""; position: absolute; left: 48%; top: 0; width: 42rpx; height: 30rpx; border: 6rpx solid #202124; border-radius: 50% 10% 50% 10%; background: #D2FF45; transform: rotate(-25deg); }.avatar__head--antenna::before { content: ""; position: absolute; left: 50%; top: 6%; height: 64rpx; border-left: 7rpx solid #202124; }.avatar__head--antenna::after { content: ""; position: absolute; left: 37%; top: 0; width: 30rpx; height: 30rpx; border: 6rpx solid #202124; border-radius: 50%; background: #F3CB42; }.avatar__head--paper-crown { left: 34%; top: 0; width: 34%; height: 17%; border: 7rpx solid #202124; background: #F3CB42; clip-path: polygon(0 100%,0 20%,28% 55%,50% 0,72% 55%,100% 18%,100% 100%); }.avatar__head--tiny-cloud { left: 36%; top: 1%; width: 30%; height: 16%; border: 7rpx solid #202124; border-radius: 50%; background: #F3EEDC; }.avatar__head--ribbon::before,.avatar__head--ribbon::after { content: ""; position: absolute; top: 22%; width: 54rpx; height: 42rpx; border: 7rpx solid #202124; background: #2B59C3; }.avatar__head--ribbon::before { left: -12rpx; border-radius: 70% 20% 70% 20%; transform: rotate(-20deg); }.avatar__head--ribbon::after { right: -12rpx; border-radius: 20% 70% 20% 70%; transform: rotate(20deg); }
.avatar__back { position: absolute; z-index: 1; left: 6%; top: 31%; width: 88%; height: 44%; }.avatar__back--wings::before,.avatar__back--wings::after { content: ""; position: absolute; top: 12%; width: 30%; height: 48%; border: 7rpx solid #202124; background: #2B59C3; }.avatar__back--wings::before { left: 0; border-radius: 70% 20% 70% 20%; }.avatar__back--wings::after { right: 0; border-radius: 20% 70% 20% 70%; }.avatar__back--shell { left: 63%; top: 30%; width: 28%; height: 46%; border: 7rpx solid #202124; border-radius: 54% 46% 46% 54%; background: #F3CB42; }.avatar__back--flag::before { content: ""; position: absolute; right: 2%; top: -18%; height: 100rpx; border-left: 7rpx solid #202124; transform: rotate(28deg); }.avatar__back--flag::after { content: ""; position: absolute; right: -4%; top: -20%; width: 62rpx; height: 42rpx; border: 7rpx solid #202124; background: #2B59C3; clip-path: polygon(0 0,100% 28%,0 100%); }.avatar__back--tail { left: 71%; top: 60%; width: 28%; height: 20%; border: 7rpx solid #202124; border-radius: 50%; background: #FF6F59; }
.avatar__texture { position: absolute; z-index: 3; left: 28%; bottom: 18%; width: 45%; height: 20%; }.avatar__texture.dots { background: radial-gradient(circle at 18% 50%,#202124 0 7rpx,transparent 8rpx),radial-gradient(circle at 52% 80%,#202124 0 6rpx,transparent 7rpx),radial-gradient(circle at 84% 34%,#202124 0 5rpx,transparent 6rpx); }.avatar__texture.stripes { border-top: 6rpx solid #202124; border-bottom: 6rpx solid #202124; border-radius: 50%; }.avatar__texture.freckles { background: radial-gradient(circle at 18% 50%,#202124 0 4rpx,transparent 5rpx),radial-gradient(circle at 46% 75%,#202124 0 3rpx,transparent 4rpx),radial-gradient(circle at 72% 42%,#202124 0 4rpx,transparent 5rpx); }.avatar__texture.patch { width: 24%; height: 24%; left: 29%; border: 6rpx solid #202124; background: #F3EEDC; transform: rotate(-10deg); }.avatar__texture.stars { width: 30%; height: 30%; left: 36%; background: #F3CB42; clip-path: polygon(50% 0,61% 35%,98% 35%,68% 55%,80% 93%,50% 70%,20% 93%,32% 55%,2% 35%,39% 35%); }.avatar__texture.squiggle { border-bottom: 7rpx solid #202124; border-radius: 50%; transform: rotate(-12deg); }
.avatar__handheld { position: absolute; z-index: 4; left: 5%; bottom: 6%; width: 72rpx; height: 72rpx; border: 7rpx solid #202124; border-radius: 50%; background: #F3CB42; }.avatar__handheld::before { content: ""; position: absolute; left: 35rpx; bottom: 48rpx; height: 74rpx; border-left: 7rpx solid #202124; transform: rotate(40deg); transform-origin: bottom; }
@keyframes float { 0%,100% { margin-top: 0; } 50% { margin-top: -10rpx; } } @keyframes blink { 0%,85%,100% { transform: scaleY(1); } 90% { transform: scaleY(.12); } }
